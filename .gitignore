# Environment — never commit secrets
.env
.env.*
!.env.example

# Node (matches node_modules/ under both backend/ and frontend/)
node_modules/
.npm

# Build output
dist/
dist-ssr/
build/

# Vite
.vite/
*.local

# TypeScript
*.tsbuildinfo

# Testing / coverage
coverage/

# Backend — Prisma generated client (regenerated via `npm run db:generate`)
backend/generated/

# Backend — uploaded files are runtime data, not source code.
# Back these up separately — losing this folder loses every
# admin-uploaded image and every applicant's submitted documents.
backend/uploads/*
!backend/uploads/.gitkeep
backend/private-uploads/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak
*~
