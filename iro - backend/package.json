{
  "name": "iro---backend",
  "version": "1.0.0",
  "description": "International Relations - IIT Dharwad ",
  "license": "ISC",
  "author": "Jayesh",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev --config src/config/prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config src/config/prisma.config.ts",
    "db:generate": "prisma generate --config src/config/prisma.config.ts",
    "db:validate": "prisma validate --config src/config/prisma.config.ts",
    "db:reset": "prisma migrate reset --config src/config/prisma.config.ts",
    "db:studio": "prisma studio --config src/config/prisma.config.ts",
    "seed": "tsx src/scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "prisma": {
    "seed": "tsx src/scripts/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
