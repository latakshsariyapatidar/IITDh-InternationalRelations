# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Authentication
JWT_SECRET=some-long-random-secret-string

CORS_ORIGIN=http://localhost:5173

SEED_ADMIN_PASSWORD=choose-a-strong-password-here

# Google OAuth (Student Sign-In, Part 37) — Web application Client ID from
# Google Cloud Console. Not a secret; safe to be public in a frontend build.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com